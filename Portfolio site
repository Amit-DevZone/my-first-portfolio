<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Amir Gautam — Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;1,300&family=Fraunces:ital,opsz,wght@0,9..144,300;1,9..144,200&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg: #0a0a0a;
    --surface: #111111;
    --border: #1e1e1e;
    --accent: #c8f562;
    --accent2: #ff6b35;
    --accent3: #5b8dee;
    --text: #f0ede8;
    --muted: #666;
    --card: #141414;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    overflow-x: hidden;
    cursor: none;
  }

  /* Custom cursor */
  .cursor {
    width: 12px; height: 12px;
    background: var(--accent);
    border-radius: 50%;
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 9999;
    transition: transform 0.15s ease, background 0.2s;
    mix-blend-mode: exclusion;
  }
  .cursor-ring {
    width: 36px; height: 36px;
    border: 1.5px solid var(--accent);
    border-radius: 50%;
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 9998;
    transition: all 0.1s ease;
    mix-blend-mode: exclusion;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    padding: 20px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(10,10,10,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    color: var(--text);
    text-decoration: none;
  }
  .logo span { color: var(--accent); }

  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
  }
  .nav-links a {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0;
    width: 0; height: 1px;
    background: var(--accent);
    transition: width 0.3s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-links a:hover::after { width: 100%; }

  .nav-cta {
    font-family: 'Syne', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 10px 24px;
    background: var(--accent);
    color: #000;
    border: none;
    cursor: none;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .nav-cta:hover { background: #d4ff6a; transform: translateY(-1px); }

  /* PAGE SECTIONS */
  section { min-height: 100vh; }

  /* ─── HERO ─── */
  #home {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 48px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .hero-noise {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .hero-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px; height: 1px;
    background: var(--accent);
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(3.5rem, 8vw, 7.5rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    opacity: 0;
    animation: fadeUp 0.9s 0.35s forwards;
    position: relative;
    z-index: 1;
  }

  .hero-title .line2 {
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(240,237,232,0.25);
    font-style: italic;
    font-family: 'Fraunces', serif;
  }

  .hero-title .line3 { color: var(--accent); }

  .hero-sub {
    max-width: 480px;
    margin-top: 36px;
    font-size: 0.85rem;
    line-height: 1.8;
    color: var(--muted);
    opacity: 0;
    animation: fadeUp 0.9s 0.5s forwards;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    margin-top: 48px;
    opacity: 0;
    animation: fadeUp 0.9s 0.65s forwards;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-family: 'Syne', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 14px 32px;
    background: var(--accent);
    color: #000;
    border: none;
    cursor: none;
    text-decoration: none;
    transition: all 0.25s;
    display: inline-block;
  }
  .btn-primary:hover { background: #d4ff6a; transform: translateY(-2px); }

  .btn-ghost {
    font-family: 'Syne', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 14px 32px;
    border: 1px solid var(--border);
    color: var(--text);
    cursor: none;
    text-decoration: none;
    transition: all 0.25s;
    display: inline-block;
  }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

  .hero-stats {
    position: absolute;
    right: 80px;
    bottom: 100px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    opacity: 0;
    animation: fadeLeft 0.9s 0.8s forwards;
  }

  .stat {
    text-align: right;
  }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-top: 4px;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 48px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0;
    animation: fadeUp 0.9s 1s forwards;
  }
  .scroll-line {
    width: 48px; height: 1px;
    background: var(--muted);
    position: relative;
    overflow: hidden;
  }
  .scroll-line::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: var(--accent);
    animation: slide 1.8s 1.5s infinite;
  }

  /* ─── ABOUT ─── */
  #about {
    padding: 120px 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    border-top: 1px solid var(--border);
  }

  .section-tag {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-tag::before { content: '//'; color: var(--muted); }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 32px;
  }

  .section-title em {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    color: transparent;
    -webkit-text-stroke: 1px rgba(240,237,232,0.4);
  }

  .about-body {
    font-size: 0.88rem;
    line-height: 1.9;
    color: rgba(240,237,232,0.65);
    margin-bottom: 24px;
  }

  .about-img-wrap {
    position: relative;
  }

  .about-img-frame {
    aspect-ratio: 4/5;
    background: var(--card);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-img-frame::before {
    content: 'AG';
    font-family: 'Syne', sans-serif;
    font-size: 8rem;
    font-weight: 800;
    color: rgba(200,245,98,0.08);
    position: absolute;
  }

  .about-img-frame .img-accent {
    position: absolute;
    bottom: -1px; right: -1px;
    width: 60%;
    height: 3px;
    background: var(--accent);
  }

  .about-img-frame .img-dot {
    position: absolute;
    top: 20px; right: 20px;
    width: 10px; height: 10px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .about-frame-decor {
    position: absolute;
    top: 20px; right: -20px;
    width: 100%; height: 100%;
    border: 1px solid var(--border);
    pointer-events: none;
  }

  .about-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 32px;
  }

  .info-item label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-bottom: 6px;
  }
  .info-item span {
    font-size: 0.82rem;
    color: var(--text);
  }

  /* ─── SKILLS ─── */
  #skills {
    padding: 120px 48px;
    border-top: 1px solid var(--border);
  }

  .skills-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 72px;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .skill-category {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 36px 32px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
  }
  .skill-category:hover { border-color: rgba(200,245,98,0.3); }
  .skill-category::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 0;
    background: var(--accent);
    transition: height 0.4s;
  }
  .skill-category:hover::before { height: 100%; }

  .skill-cat-icon {
    font-size: 1.5rem;
    margin-bottom: 16px;
  }

  .skill-cat-title {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 24px;
    letter-spacing: -0.01em;
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
    list-style: none;
  }

  .skill-item {
    font-size: 0.78rem;
  }

  .skill-bar-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 6px;
  }

  .skill-name { color: rgba(240,237,232,0.7); flex: 1; }

  .skill-bar {
    flex: 2;
    height: 3px;
    background: var(--border);
    position: relative;
    overflow: hidden;
  }
  .skill-bar-fill {
    position: absolute;
    top: 0; left: 0; height: 100%;
    background: var(--accent);
    width: 0;
    transition: width 1.2s ease;
  }

  .skill-pct {
    font-size: 0.65rem;
    color: var(--muted);
    width: 28px;
    text-align: right;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .tech-tag {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    padding: 5px 12px;
    border: 1px solid var(--border);
    color: var(--muted);
    transition: all 0.2s;
  }
  .tech-tag:hover { border-color: var(--accent); color: var(--accent); }

  /* ─── PROJECTS ─── */
  #projects {
    padding: 120px 48px;
    border-top: 1px solid var(--border);
  }

  .projects-filter {
    display: flex;
    gap: 8px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 18px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: none;
    transition: all 0.2s;
  }
  .filter-btn.active, .filter-btn:hover {
    background: var(--accent);
    color: #000;
    border-color: var(--accent);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }

  .project-card {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 40px;
    position: relative;
    overflow: hidden;
    transition: all 0.35s;
    display: flex;
    flex-direction: column;
  }
  .project-card:hover { border-color: rgba(200,245,98,0.25); transform: translateY(-4px); }
  .project-card.featured { grid-column: span 2; }

  .project-card-bg {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s;
    background: radial-gradient(circle at 70% 30%, rgba(200,245,98,0.04), transparent 60%);
  }
  .project-card:hover .project-card-bg { opacity: 1; }

  .project-num {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin-bottom: 20px;
  }

  .project-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .project-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    flex: 1;
  }

  .project-link-icon {
    font-size: 1.1rem;
    color: var(--muted);
    transition: color 0.2s, transform 0.2s;
    margin-left: 16px;
    text-decoration: none;
    cursor: none;
  }
  .project-card:hover .project-link-icon { color: var(--accent); transform: translate(4px, -4px); }

  .project-desc {
    font-size: 0.8rem;
    line-height: 1.8;
    color: rgba(240,237,232,0.55);
    margin-bottom: 28px;
    flex: 1;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 24px;
  }

  .p-tag {
    font-size: 0.63rem;
    letter-spacing: 0.1em;
    padding: 4px 10px;
    background: rgba(200,245,98,0.07);
    color: var(--accent);
    border: 1px solid rgba(200,245,98,0.15);
  }

  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .project-year {
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  .project-status {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 0;
  }
  .status-live { background: rgba(200,245,98,0.1); color: var(--accent); border: 1px solid rgba(200,245,98,0.2); }
  .status-dev { background: rgba(91,141,238,0.1); color: var(--accent3); border: 1px solid rgba(91,141,238,0.2); }

  /* ─── EXPERIENCE ─── */
  #experience {
    padding: 120px 48px;
    border-top: 1px solid var(--border);
  }

  .exp-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 80px;
    margin-top: 60px;
  }

  .exp-nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: sticky;
    top: 120px;
    align-self: start;
  }

  .exp-nav-item {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 14px 16px;
    border-left: 2px solid var(--border);
    color: var(--muted);
    cursor: none;
    transition: all 0.2s;
  }
  .exp-nav-item.active, .exp-nav-item:hover {
    border-left-color: var(--accent);
    color: var(--text);
    background: rgba(200,245,98,0.03);
    padding-left: 24px;
  }

  .exp-entries {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .exp-entry {
    border-left: 1px solid var(--border);
    padding-left: 32px;
    position: relative;
  }
  .exp-entry::before {
    content: '';
    position: absolute;
    top: 6px; left: -5px;
    width: 9px; height: 9px;
    background: var(--border);
    border-radius: 50%;
    border: 2px solid var(--bg);
    transition: background 0.3s;
  }
  .exp-entry:hover::before { background: var(--accent); }

  .exp-company {
    font-family: 'Syne', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }

  .exp-role {
    font-size: 0.78rem;
    color: var(--accent);
    margin-bottom: 10px;
    letter-spacing: 0.06em;
  }

  .exp-date {
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .exp-desc {
    font-size: 0.82rem;
    line-height: 1.85;
    color: rgba(240,237,232,0.6);
  }

  .exp-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 16px;
  }
  .exp-badge {
    font-size: 0.62rem;
    padding: 4px 10px;
    border: 1px solid var(--border);
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  /* ─── CONTACT ─── */
  #contact {
    padding: 120px 48px;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .contact-bg {
    position: absolute;
    bottom: 0; right: 0;
    width: 50%;
    height: 100%;
    background: radial-gradient(circle at 80% 50%, rgba(200,245,98,0.04), transparent 60%);
    pointer-events: none;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .contact-headline {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin-bottom: 32px;
  }
  .contact-headline span { color: var(--accent); }

  .contact-subtitle {
    font-size: 0.85rem;
    line-height: 1.8;
    color: var(--muted);
    margin-bottom: 40px;
  }

  .contact-socials {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    transition: all 0.2s;
    cursor: none;
  }
  .social-link:hover { color: var(--text); padding-left: 8px; }
  .social-link:hover .social-arrow { color: var(--accent); }
  .social-platform {
    font-family: 'Syne', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
  }
  .social-arrow { margin-left: auto; transition: transform 0.2s; }
  .social-link:hover .social-arrow { transform: translate(4px,-2px); }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .form-input, .form-textarea {
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.82rem;
    padding: 14px 16px;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    cursor: none;
  }
  .form-input:focus, .form-textarea:focus { border-color: var(--accent); }
  .form-textarea { resize: vertical; min-height: 120px; }

  .form-submit {
    font-family: 'Syne', sans-serif;
    font-size: 0.82rem;
